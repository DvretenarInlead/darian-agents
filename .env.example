# ============================================================================
# darian-agents — environment configuration template
# Copy to .env for local dev. NEVER commit a real .env (see .gitignore).
# In production these are supplied as DigitalOcean App Platform secrets.
# ============================================================================

# --- Runtime ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# --- Postgres (DO Managed Postgres) ---
# The application connects with a least-privilege role. The audit_log table is
# granted INSERT + SELECT only for this role (no UPDATE/DELETE) — see migrations.
DATABASE_URL=postgres://app:password@localhost:5432/darian_agents
DATABASE_SSL=false

# --- App-level envelope encryption ---
# Master key (base64, 32 bytes) used to wrap per-record data keys for the most
# sensitive columns (raw transcripts, repo content, owner/MFA metadata).
# Rotate on the documented cadence; keep prior key versions for decryption.
ENVELOPE_MASTER_KEY=
ENVELOPE_KEY_VERSION=1

# --- Anthropic (commercial API terms — no training on inputs) ---
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-8

# --- Fireflies (Product A ingestion) ---
FIREFLIES_API_KEY=
# Shared secret used to verify inbound webhook HMAC signatures.
FIREFLIES_WEBHOOK_SECRET=
# Reject webhook payloads whose timestamp is older than this (seconds).
WEBHOOK_TIMESTAMP_TOLERANCE_SEC=300

# --- HubSpot (Agent CLI default; Projects API version-pinned fallback) ---
HUBSPOT_ACCESS_TOKEN=
# Broad-permission service key — admin-mode only, gated behind a dedicated role.
HUBSPOT_SERVICE_KEY=
HUBSPOT_PROJECTS_API_VERSION=2026-03

# --- GitHub (Product B repo scoring) ---
GITHUB_TOKEN=

# --- Console auth / sessions ---
SESSION_ACCESS_TTL_SEC=900
SESSION_IDLE_TTL_SEC=1800
SESSION_ABSOLUTE_TTL_SEC=43200
SUDO_REAUTH_WINDOW_SEC=300

# --- Egress allowlist (comma-separated hostnames the workers may reach) ---
EGRESS_ALLOWLIST=api.anthropic.com,api.fireflies.ai,api.hubapi.com,api.github.com

# --- Off-box audit shipping ---
AUDIT_SHIP_ENDPOINT=
AUDIT_SHIP_TOKEN=
