{
  "name": "darian-agents",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-orchestration platform: Meeting→Task Engine + Repo Scoring on shared infrastructure",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "check-env": "tsx scripts/check-env.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.2",
    "fastify": "^5.7.2",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  }
}
